# Anthropic API key for Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# GitHub token (optional, increases rate limits)
GITHUB_TOKEN=your-github-token

# RapidAPI proxy secret (get from RapidAPI dashboard → My APIs → Security)
# When set, only requests from RapidAPI are accepted
RAPIDAPI_PROXY_SECRET=your-proxy-secret
